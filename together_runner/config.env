# together_runner — unified configuration (the ONLY place you pre-set variables)
#
# Usage: every script does `source config.env`. Override any value by exporting
# it in your shell BEFORE sourcing, or by editing the defaults below.
#
# This file is sourced, not executed. Keep it side-effect free.

# ----------------------------------------------------------------------------
# Standardized paths
# ----------------------------------------------------------------------------
# HuggingFace token. Prefer a file on disk; fall back to env. `hf auth login`
# writes the token to $HOME/.cache/huggingface/token by default.
export HF_TOKEN_FILE="${HF_TOKEN_FILE:-$HOME/.cache/huggingface/token}"
export HF_TOKEN="${HF_TOKEN:-$(cat "$HF_TOKEN_FILE" 2>/dev/null || true)}"

# HF hub cache (holds blobs/ + the content-addressed hashes). On this node /home
# and /scratch are the same 14TB array; the small 34GB root disk must be avoided.
export HF_CACHE="${HF_CACHE:-/scratch/home/johnson/huggingface}"

# Root for externally pre-staged weights (see prestage_weights.sh). Keeping a
# stable local dir lets the server start with zero download.
export MODELS_ROOT="${MODELS_ROOT:-/scratch/home/johnson/models}"

# Persistent FlashInfer JIT-compile cache (mounted into the container so compiled
# kernels survive restarts).
export FLASHINFER_CACHE="${FLASHINFER_CACHE:-/scratch/home/johnson/flashinfer-cache}"

# ----------------------------------------------------------------------------
# Engine + Model / recipe
# ----------------------------------------------------------------------------
# ENGINE selects the inference engine (== framework dimension in results/baselines).
export ENGINE="${ENGINE:-sglang}"   # sglang | vllm

# PROFILE selects a recipe; run_2 builds the launch command from (ENGINE, PROFILE).
#   dsr1-fp4   - DeepSeek-R1 FP4, TP8/EP8   (sglang)
#   gptoss-fp4 - gpt-oss-120b FP4, TP4      (vllm)
#   smoke      - Llama-3.1-8B-Instruct, TP1 (either engine; sanity only)
export PROFILE="${PROFILE:-dsr1-fp4}"

# Per-profile defaults for MODEL/TP/EP_SIZE (only fill if caller didn't export them).
case "$PROFILE" in
  dsr1-fp4)   : "${MODEL:=nvidia/DeepSeek-R1-0528-FP4}"; : "${TP:=8}"; : "${EP_SIZE:=8}" ;;
  gptoss-fp4) : "${MODEL:=openai/gpt-oss-120b}";         : "${TP:=4}"; : "${EP_SIZE:=0}" ;;
  smoke)      : "${MODEL:=meta-llama/Llama-3.1-8B-Instruct}"; : "${TP:=1}"; : "${EP_SIZE:=0}" ;;
  *)          : "${MODEL:=}"; : "${TP:=8}"; : "${EP_SIZE:=0}" ;;
esac
export MODEL TP EP_SIZE
# Pin a commit/revision for reproducible baselines ("main" = latest).
export MODEL_REVISION="${MODEL_REVISION:-main}"

# Benchmark shape (used by run_3 + result naming).
export ISL="${ISL:-1024}"
export OSL="${OSL:-1024}"
export CONC="${CONC:-16}"

# ----------------------------------------------------------------------------
# Tuning switch — default OFF for first runs, turn ON for the official perf pass.
# ----------------------------------------------------------------------------
# sglang: ENABLE_TUNING=0 -> `--disable-flashinfer-autotune` (skips the slow
#   fp4_gemm autotune, ~12 min off cold start); =1 keeps it (peak perf, baselines).
# vllm:   no separable fp4 autotune — ENABLE_TUNING only tags the baseline key
#   (tuned/untuned), it does NOT change vLLM flags.
export ENABLE_TUNING="${ENABLE_TUNING:-0}"

# ----------------------------------------------------------------------------
# Container / serving
# ----------------------------------------------------------------------------
# Per-engine default image (override with IMAGE=...).
case "$ENGINE" in
  sglang) : "${IMAGE:=lmsysorg/sglang:dev-cu13}" ;;
  vllm)   : "${IMAGE:=vllm/vllm-openai:v0.22.0}" ;;
esac
export IMAGE
# One container per engine so sglang/vllm don't clobber each other.
export CONTAINER_NAME="${CONTAINER_NAME:-tr_${ENGINE}}"
export PORT="${PORT:-8888}"

# InferenceX repo root — mounted read-only into the container so the unified
# benchmark client (utils/bench_serving/benchmark_serving.py) is available.
export REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

# Hardware tag + cluster/provider — used in result/baseline paths and the
# InferenceX schema. Same HW may exist on several clusters; set CLUSTER per box.
export HW="${HW:-b200}"
export CLUSTER="${CLUSTER:-together}"

# ----------------------------------------------------------------------------
# Derived: seq-len tag (1k1k, 8k1k, ...) used in result/baseline directory keys.
# ----------------------------------------------------------------------------
_seqtag() { local n="$1"; if (( n % 1024 == 0 )); then echo "$((n/1024))k"; else echo "${n}"; fi; }
export SEQ_TAG="${SEQ_TAG:-$(_seqtag "$ISL")$(_seqtag "$OSL")}"
